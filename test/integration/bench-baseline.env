# Subnetra data-plane benchmark baseline (issue #97)
#
# Reproducible single-host netns benchmark recorded by test/integration/bench.sh.
# This is the CI/host baseline a data-plane perf change is diffed against. It now
# INCLUDES the issue #100 recvmmsg/sendmmsg batching (the path that landed it
# improved the single-syscall v0.5.1 reference by +9.8% spoke->hub / +11.7% relay;
# see PR #123). A future data-plane perf change must show a measurable gain over
# these numbers.
# It is INFORMATIONAL — shared CI runners vary run-to-run, so the harness surfaces
# the delta but never fails on a regression. Re-record it on the same class of
# runner when the number meaningfully shifts (and note the environment below).
#
# It is NOT the live-overlay field measurement (that is deploy/bench-overlay.sh,
# issue #102, which exercises real NAT/WAN). The SHIPPED daemon always stays
# -O ReleaseSmall (iron law #6); these numbers come from a -Doptimize=ReleaseFast
# measurement build only.
#
# Environment: GitHub-hosted ubuntu-latest runner, hub pinned to its own core.
# KEY=VALUE; consumed by bench.sh's baseline diff.

subnetra_version=0.5.1
git_commit=4f302ca
zig_version=0.16.0
arch=x86_64
secs_per_pattern=5
inner_bytes=1400

# Pattern 1 — spoke -> hub (hub terminates; one AEAD open per packet).
spoke_hub_pps=101050
spoke_hub_gbps=1.132
spoke_hub_hub_cpu_pct=99.1

# Pattern 2 — spoke -> hub -> spoke (RELAY; hub pays recv+send AND open+seal per
# packet — the path issue #100's recvmmsg/sendmmsg batching targets). This is the
# headline number: the single-core hub relay ceiling. The hub still sits at ~100%
# of ONE core while the generator offers several times this load (achieved <<
# offered), so the daemon's per-packet work is the proven bottleneck.
relay_pps=65832
relay_gbps=0.737
relay_hub_cpu_pct=100.2
